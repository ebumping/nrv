{
  "name": "@nrv/components",
  "version": "0.1.0",
  "description": "Futuristic HUD/LCARS-style React component library",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "components",
    "hud",
    "lcars",
    "futuristic",
    "sci-fi",
    "ui"
  ],
  "license": "MIT"
}
